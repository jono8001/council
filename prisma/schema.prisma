generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceScope {
  central
  local
}

enum SourceType {
  transparency
  finance_reports
  procurement
  meetings
}

enum SourceFormat {
  html
  csv
  xlsx
  xls
  pdf
  json
}

enum SourceStatus {
  active
  inactive
  blocked
}

enum DataLayer {
  annual_baseline
  quarterly_update
  local_spend
  composite_watch
}

enum PeriodKind {
  annual
  quarterly
  monthly
  ad_hoc
}

enum CoverageStatus {
  full
  partial
  minimal
  none
}

enum SignalCategory {
  structural
  current_warning
  spend_pattern
  procurement
  governance_history
}

enum Severity {
  low
  medium
  high
}

enum Band {
  Guarded
  Elevated
  Critical
}

enum IngestionStatus {
  running
  success
  partial
  failed
}

model Authority {
  id                String                    @id @default(cuid())
  name              String
  slug              String                    @unique
  onsCode            String?                   @unique
  type              String
  region            String
  officialUrl       String?
  coverageNote      String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  sources           Source[]
  documents         Document[]
  spendTransactions SpendTransaction[]
  contractAwards    ContractAward[]
  signals           Signal[]
  scoreSnapshots    ScoreSnapshot[]
  annualBaselines   AnnualBaselineSnapshot[]
  quarterlyPositions QuarterlyPositionSnapshot[]

  @@index([slug])
}

model Source {
  id                  String       @id @default(cuid())
  authorityId          String
  authority            Authority    @relation(fields: [authorityId], references: [id], onDelete: Cascade)
  scope                SourceScope  @default(local)
  sourceType           SourceType
  baseUrl              String
  sourceFormat         SourceFormat
  parserName           String
  status               SourceStatus @default(active)
  provenancePublisher  String?
  provenanceDataset    String?
  provenanceUrl        String?
  lastFetchedAt        DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  documents            Document[]

  @@unique([authorityId, sourceType, baseUrl])
  @@index([authorityId, sourceType])
}

model Document {
  id                  String      @id @default(cuid())
  authorityId         String
  authority           Authority   @relation(fields: [authorityId], references: [id], onDelete: Cascade)
  sourceId            String?
  source              Source?     @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  layer               DataLayer?
  title               String
  url                 String
  publicationDate     DateTime?
  format              SourceFormat
  periodKind          PeriodKind?
  periodLabel         String?
  periodStart         DateTime?
  periodEnd           DateTime?
  provenancePublisher String?
  extractedText       String?
  checksum            String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  signals             Signal[]

  @@unique([authorityId, layer, url, periodLabel])
}

model SpendTransaction {
  id          String   @id @default(cuid())
  authorityId String
  authority   Authority @relation(fields: [authorityId], references: [id], onDelete: Cascade)
  date        DateTime?
  supplier    String
  amount      Decimal  @db.Decimal(14, 2)
  serviceArea String?
  description String?
  sourceUrl   String?
  createdAt   DateTime @default(now())

  @@index([authorityId, date])
}

model ContractAward {
  id            String   @id @default(cuid())
  authorityId   String
  authority     Authority @relation(fields: [authorityId], references: [id], onDelete: Cascade)
  title         String
  supplier      String
  value         Decimal  @db.Decimal(14, 2)
  awardedAt     DateTime?
  sourceUrl     String?
  createdAt     DateTime @default(now())
}

model Signal {
  id           String         @id @default(cuid())
  authorityId  String
  authority    Authority      @relation(fields: [authorityId], references: [id], onDelete: Cascade)
  documentId   String?
  document     Document?      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  category     SignalCategory
  severity     Severity
  title        String
  evidenceText String
  sourceUrl    String
  weight       Int
  detectedAt   DateTime
  createdAt    DateTime       @default(now())

  @@index([authorityId, detectedAt])
}

model AnnualBaselineSnapshot {
  id                  String         @id @default(cuid())
  authorityId         String
  authority           Authority      @relation(fields: [authorityId], references: [id], onDelete: Cascade)
  financialYear       String
  layer               DataLayer      @default(annual_baseline)
  netRevenueBudget    Decimal?       @db.Decimal(14, 2)
  reservesLevel       Decimal?       @db.Decimal(14, 2)
  debtLevel           Decimal?       @db.Decimal(14, 2)
  explanation         String
  sourceUrl           String?
  coverageStatus      CoverageStatus @default(partial)
  confidenceScore     Int?
  freshnessDays       Int?
  recordedAt          DateTime       @default(now())

  @@unique([authorityId, financialYear])
  @@index([authorityId, recordedAt])
}

model QuarterlyPositionSnapshot {
  id                  String         @id @default(cuid())
  authorityId         String
  authority           Authority      @relation(fields: [authorityId], references: [id], onDelete: Cascade)
  financialYear       String
  quarter             Int
  layer               DataLayer      @default(quarterly_update)
  budgetToDate        Decimal?       @db.Decimal(14, 2)
  outturnToDate       Decimal?       @db.Decimal(14, 2)
  varianceToDate      Decimal?       @db.Decimal(14, 2)
  explanation         String
  sourceUrl           String?
  coverageStatus      CoverageStatus @default(partial)
  confidenceScore     Int?
  freshnessDays       Int?
  recordedAt          DateTime       @default(now())

  @@unique([authorityId, financialYear, quarter])
  @@index([authorityId, recordedAt])
}

model ScoreSnapshot {
  id                     String         @id @default(cuid())
  authorityId            String
  authority              Authority       @relation(fields: [authorityId], references: [id], onDelete: Cascade)
  layer                  DataLayer       @default(composite_watch)
  structural             Int
  currentWarning         Int
  spendPattern           Int
  procurement            Int
  governanceHistory      Int
  overall                Int
  band                   Band
  explanation            String
  borrowingIndicator     String
  reservesSignal         String
  publicationStatus      String
  coverageStatus         CoverageStatus  @default(partial)
  confidenceScore        Int?
  freshnessDays          Int?
  recordedAt             DateTime        @default(now())
}

model DailyBriefing {
  id          String   @id @default(cuid())
  briefingDate DateTime @unique
  headline    String
  body        String
  createdAt   DateTime @default(now())
}

model IngestionRun {
  id                 String          @id @default(cuid())
  status             IngestionStatus @default(running)
  authoritiesCount   Int             @default(0)
  documentsCount     Int             @default(0)
  spendRowsCount     Int             @default(0)
  contractsCount     Int             @default(0)
  signalsCount       Int             @default(0)
  errors             Json?
  startedAt          DateTime        @default(now())
  completedAt        DateTime?
}
