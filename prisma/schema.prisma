generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum DeliveryProvider {
  uber_eats
  just_eat
  deliveroo
}

enum DataSource {
  api
  csv_import
  manual_entry
  unavailable
}

model McdonaldsLocation {
  id               String   @id @default(cuid())
  storeNumber      String?
  name             String
  address          String
  postcode         String?
  latitude         Float
  longitude        Float
  googlePlaceId    String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  snapshots        CompetitorSnapshot[]
  operatorNotes    OperatorNote[]
}

model Competitor {
  id               String   @id @default(cuid())
  googlePlaceId    String   @unique
  name             String
  address          String
  postcode         String?
  latitude         Float
  longitude        Float
  primaryCategory  String?
  googleRating     Float?
  googleReviewCount Int?
  googleMapsUrl    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  snapshots        CompetitorSnapshot[]
  deliveryRatings  DeliveryRating[]
  operatorNotes    OperatorNote[]
}

model CompetitorSnapshot {
  id                  String   @id @default(cuid())
  mcdonaldsLocationId String
  competitorId        String
  radiusMiles         Float
  distanceMiles       Float
  rank                Int
  threatScore         Int
  createdAt           DateTime @default(now())
  mcdonaldsLocation   McdonaldsLocation @relation(fields: [mcdonaldsLocationId], references: [id], onDelete: Cascade)
  competitor          Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([mcdonaldsLocationId, createdAt])
}

model DeliveryRating {
  id                   String   @id @default(cuid())
  competitorId         String
  provider             DeliveryProvider
  providerRestaurantId String?
  providerUrl          String?
  rating               Float?
  reviewCount          Int?
  dataSource           DataSource
  confidence           Float
  lastUpdated          DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  competitor           Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@unique([competitorId, provider])
}

model OperatorNote {
  id                  String   @id @default(cuid())
  competitorId        String
  mcdonaldsLocationId String
  note                String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  competitor          Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  mcdonaldsLocation   McdonaldsLocation @relation(fields: [mcdonaldsLocationId], references: [id], onDelete: Cascade)

  @@index([competitorId, mcdonaldsLocationId])
}
